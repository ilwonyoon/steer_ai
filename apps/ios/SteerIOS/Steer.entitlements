<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Steer iOS uses Sign in with Apple to authenticate against
	     the relay backend. The CloudKit entitlements that used to
	     live here were removed when the project pivoted from
	     CloudKit to a Cloudflare Workers relay (see
	     docs/RELAY_BACKEND_PLAN.md). -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!-- Push notifications: use development environment for Xcode
	     builds; release-mac.sh / TestFlight builds switch this to
	     production via the App Store Connect provisioning. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
