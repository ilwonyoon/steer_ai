<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Direct-distribution build for Mac.
         Sign in with Apple, application-identifier, and team-identifier
         are intentionally NOT requested here because they are restricted
         entitlements that only Apple Distribution / Development
         provisioning profiles can grant. With them in place on a
         Developer ID bundle, macOS 26 launchd refuses to spawn the app
         (RBSRequestErrorDomain Code=5 / errno 163). Re-add them only when
         the iPhone Sync companion ships through the Mac App Store. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
