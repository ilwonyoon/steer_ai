<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sign in with Apple is a restricted capability. It works when:
           1. The bundle is signed with a Developer ID identity
              (Apple Development also works for local installs).
           2. The matching provisioning profile is embedded so AKAuthentication
              can resolve the application-identifier claim above to a real
              App ID in our Apple Developer account.
         scripts/build-mac-app.sh handles (2) via PROVISIONING_PROFILE. -->
    <key>com.apple.developer.applesignin</key>
    <array>
        <string>Default</string>
    </array>
    <key>com.apple.developer.team-identifier</key>
    <string>LG7667PAS6</string>
    <key>com.apple.application-identifier</key>
    <string>LG7667PAS6.ai.steer.mac</string>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
