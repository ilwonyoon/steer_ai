.DS_Store
.build/
*.app/
DerivedData/
*.xcuserstate
*.xcuserdata/
# Xcode build output dumped at apps/<platform>/build (when xcodebuild
# is invoked with -derivedDataPath pointing here). Don't let it slip
# into commits — used to ship 2.8k stale intermediate files before
# this rule existed.
apps/*/build/
node_modules/
package-lock.json
.claude/settings.local.json
.claude/scheduled_tasks.lock
apps/mac/Resources/AppIcon.icns

# relay backend
packages/relay/node_modules/
packages/relay/.wrangler/
packages/relay/.dev.vars

# one-shot secret-loading helpers (created locally, not for the repo)
/add-team-id.sh
/setup-apns-secrets.sh
*.p12
*.provisionprofile
*.p8
